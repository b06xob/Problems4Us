# Problems4Us Environment Configuration

# Azure SQL Database (existing server: prius.database.windows.net)
AZURE_SQL_CONNECTION_STRING=Server=tcp:prius.database.windows.net,1433;Database=Problems4UsDB;User ID=your-user;Password=your-password;Encrypt=true;
AZURE_SQL_SERVER=prius.database.windows.net
AZURE_SQL_DATABASE=Problems4UsDB
AZURE_SQL_USER=your-user
AZURE_SQL_PASSWORD=your-password

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# Alternative: OpenAI direct
# OPENAI_API_KEY=sk-...

# AI Provider: "azure-openai" | "openai" | "mock"
AI_PROVIDER=mock

# App
# Local: http://localhost:3000  |  Production: https://problems4us.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Problems4Us

# Stripe checkout (Month-2 / G7)
# Routes exist and fail-closed until these are set:
#   POST /api/checkout/session  → creates Checkout Session via Stripe REST when set
#   POST /api/checkout/webhook  → 503 until STRIPE_WEBHOOK_SECRET; verifier next
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BUILDER_MONTHLY=price_...

# Authentication (future)
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# Owner / admin API access — required for /admin, ingest, source management, and AI tool endpoints.
# Generate a long random string and set the same value in Azure App Service application settings.
ADMIN_API_KEY=

# Data Source API Keys
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# GITHUB_TOKEN=

# Reddit OAuth — must match the redirect URI registered in your Reddit app exactly
# For local dev:  http://localhost:3000/auth/reddit/callback
# For production: https://problems4us.com/auth/reddit/callback
REDDIT_REDIRECT_URI=
