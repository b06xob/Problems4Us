# Problems4Us Environment Configuration

# Azure SQL Database (existing server: prius.database.windows.net)
AZURE_SQL_CONNECTION_STRING=Server=tcp:prius.database.windows.net,1433;Database=Problems4UsDB;User ID=your-user;Password=your-password;Encrypt=true;
AZURE_SQL_SERVER=prius.database.windows.net
AZURE_SQL_DATABASE=Problems4UsDB
AZURE_SQL_USER=your-user
AZURE_SQL_PASSWORD=your-password

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# Alternative: OpenAI direct
# OPENAI_API_KEY=sk-...

# AI Provider: "azure-openai" | "openai" | "mock"
AI_PROVIDER=mock

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Problems4Us

# Authentication (future)
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# Data Source API Keys
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# GITHUB_TOKEN=

# Reddit OAuth — must match the redirect URI registered in your Reddit app exactly
# For local dev:  http://localhost:3000/auth/reddit/callback
# For production: https://your-domain.com/auth/reddit/callback
REDDIT_REDIRECT_URI=
